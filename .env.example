# ============================================================
# FreeFrame — Environment Configuration
# ============================================================
#
# Development:
#   cp .env.example .env
#   docker compose -f docker-compose.dev.yml up --build
#   (Dev compose overrides most values below with local defaults)
#
# Production:
#   cp .env.example .env.prod
#   Edit .env.prod with your real credentials
#   docker compose --env-file .env.prod -f docker-compose.prod.yml up -d --build
#
# ============================================================

# ─── Database ───────────────────────────────────────────────
# Dev: auto-overridden by docker-compose.dev.yml (local Postgres)
# Prod: set a strong password or use an external database
POSTGRES_USER=freeframe
POSTGRES_PASSWORD=freeframe
POSTGRES_DB=freeframe
DATABASE_URL=postgresql://freeframe:freeframe@localhost:5432/freeframe

# External database (RDS, Supabase, Neon, etc.):
# Remove the postgres service from compose, then set:
# DATABASE_URL=postgresql://user:password@your-db-host:5432/freeframe

# ─── Redis / Valkey ─────────────────────────────────────────
# Dev: no password needed (auto-overridden by dev compose)
# Prod: set a password or use an external Redis/Valkey instance
REDIS_PASSWORD=
REDIS_URL=redis://localhost:6379/0

# External Redis/Valkey (Upstash, ElastiCache, etc.):
# Remove the redis service from compose, then set:
# REDIS_URL=redis://:password@your-redis-host:6379/0

# ─── S3 Storage ─────────────────────────────────────────────
# Dev: "minio" uses the local MinIO container
# Prod: "s3" for any S3-compatible provider (AWS, R2, B2, Spaces, etc.)
S3_STORAGE=minio
S3_BUCKET=freeframe
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_REGION=us-east-1
S3_ENDPOINT=http://localhost:9000
# S3_PUBLIC_ENDPOINT=          # Only if presigned URLs need a different base URL

# Production S3 example (uncomment and fill in):
# S3_STORAGE=s3
# S3_BUCKET=your-freeframe-bucket
# S3_ACCESS_KEY=YOUR_S3_ACCESS_KEY
# S3_SECRET_KEY=YOUR_S3_SECRET_KEY
# S3_REGION=us-east-1
# S3_ENDPOINT=                 # Set for non-AWS (e.g., https://acct.r2.cloudflarestorage.com)

# ─── NAS storage via MinIO (Synology / QNAP / TrueNAS / Unraid) ─────
# Run MinIO on your NAS (see docs/nas-storage.md) so media lives on NAS
# disks while FreeFrame keeps talking S3. Keep S3_STORAGE=minio so the
# app sends requests to your endpoint instead of AWS.
#   S3_STORAGE=minio
#   S3_BUCKET=freeframe
#   S3_ACCESS_KEY=<MinIO access key you create on the NAS>
#   S3_SECRET_KEY=<MinIO secret key you create on the NAS>
#   S3_REGION=us-east-1
#   S3_ENDPOINT=http://<nas-ip-or-host>:9000          # reached by the API/worker
#   S3_PUBLIC_ENDPOINT=http://<nas-ip-or-host>:9000   # reached by the browser
# If the browser and the API reach the NAS at the same address (typical on a
# LAN), S3_ENDPOINT and S3_PUBLIC_ENDPOINT are identical. Use https:// URLs if
# you put MinIO behind TLS.

# ─── Auth ───────────────────────────────────────────────────
# Prod: generate a strong secret →  openssl rand -hex 64
# MUST be changed from the default — it signs JWTs AND encrypts share-link
# passwords. A default/leaked value lets an attacker forge admin sessions.
JWT_SECRET=change-me-to-a-secure-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ─── Proxy / rate limiting ──────────────────────────────────
# Number of trusted reverse proxies in front of the API. Traefik (the bundled
# prod proxy) = 1. Set 0 only if the API is exposed directly with no proxy.
# This is how the API derives the real client IP for rate limiting; a wrong
# value makes per-IP throttling either ineffective or overly aggressive.
TRUSTED_PROXY_COUNT=1

# ─── Data retention (POPIA) ─────────────────────────────────
# Days after a record is soft-deleted before the daily retention job strips
# its personal data. Share-link activity logs older than the activity window
# are purged. See docs/security-hardening.md.
RETENTION_ERASE_AFTER_DAYS=30
RETENTION_ACTIVITY_DAYS=365

# ─── Frontend ───────────────────────────────────────────────
# NOTE: This does NOT need to match how you reach the app. Access is
# host-independent — the browser calls the API at the relative "/api" path and
# in-app links use the current origin, so the app works from localhost, a
# LAN/Tailscale IP, or a domain with no change here.
#
# FRONTEND_URL is only used to build absolute links inside OUTBOUND EMAILS
# (invites, mentions, share notifications), which are sent by background workers
# that have no request to derive the host from. Set it to a STABLE address —
# your domain once you have one — not an ephemeral IP. If you don't send email,
# it doesn't matter.
FRONTEND_URL=http://localhost:3000

# ─── Frontend → API path (relative by default) ──────────────
# The browser calls the API at the SAME origin via "/api", so there is no CORS
# and no hardcoded host — it works locally, over Tailscale, and behind a proxy.
# A reverse proxy (or the bundled Next rewrite) forwards "/api" to the API.
#   NEXT_PUBLIC_API_URL=/api          # what the browser calls (leave as /api)
#   API_PROXY_TARGET=http://api:8000  # where the Next server forwards /api
# The dev compose sets both already. Only override NEXT_PUBLIC_API_URL if you
# serve the API on a different absolute URL and accept the CORS setup.

# ─── Email ──────────────────────────────────────────────────
# Option 1: SMTP (Mailgun, Postmark, SendGrid, self-hosted, etc.)
MAIL_PROVIDER=smtp
MAIL_FROM_ADDRESS=noreply@example.com
MAIL_FROM_NAME=FreeFrame
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_USE_TLS=true

# Option 2: AWS SES
# MAIL_PROVIDER=ses
# MAIL_FROM_ADDRESS=noreply@your-domain.com
# MAIL_FROM_NAME=FreeFrame
# AWS_MAIL_ACCESS_KEY_ID=YOUR_SES_ACCESS_KEY
# AWS_MAIL_SECRET_ACCESS_KEY=YOUR_SES_SECRET_KEY
# AWS_MAIL_REGION=us-east-1

# ─── SSL (Production only) ──────────────────────────────────
# Set DOMAIN and ACME_EMAIL to enable automatic Let's Encrypt SSL.
# Without these, FreeFrame runs on HTTP only (port 80).
DOMAIN=your-domain.com
ACME_EMAIL=admin@your-domain.com

# ─── Workers & Performance ──────────────────────────────────
API_WORKERS=4                  # Gunicorn worker processes (prod only)
TRANSCODING_CONCURRENCY=2     # Parallel video transcoding jobs (CPU intensive)
EMAIL_CONCURRENCY=2            # Parallel email sending jobs
TRANSCODER_ENGINE=ffmpeg
